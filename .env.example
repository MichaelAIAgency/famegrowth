# Public site URL (used for canonical tags, sitemap, OG). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://famegrowth.de

# Owner WhatsApp number in international format, digits only (no +, no spaces).
# Example for Germany: 491701234567
NEXT_PUBLIC_WHATSAPP_NUMBER=491701234567

# Where lead form notifications should be delivered (used by /api/lead once wired up).
LEAD_NOTIFY_EMAIL=kontakt@famegrowth.de
